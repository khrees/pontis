{
  "name": "pontis",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "npx wrangler dev",
    "deploy": "npx wrangler deploy",
    "build": "npm run build:proxy",
    "build:proxy": "esbuild src/local-server.ts --bundle --platform=node --target=node18 --outfile=dist/proxy.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "esbuild": "^0.25.0",
    "pkg": "^5.8.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.87.0"
  },
  "license": "MIT",
  "description": "A bidirectional translation proxy bridging Anthropic and OpenAI API formats to run Claude Code, Codex CLI, and other terminal-based AI harnesses using local models or OpenCode.",
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "hono": "^4.12.17"
  }
}
