#!/usr/bin/env bash

# =============================================
#  Pontis (OpenCode ↔ Claude Code/Codex Bridge)
#  Uses OpenCode's free models or locally
#  installed models (Ollama, LM Studio) through
#  terminal harnesses like Claude Code or Codex CLI.
# =============================================

set -e

PROXY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KEY_FILE="$HOME/.opencode_api_key"
PORT=8787
PROXY_URL="http://localhost:$PORT"

# ─────────────────────────────────────────────
# 1. Select API Provider
# ─────────────────────────────────────────────
PROVIDER=""
if [ -n "$PONTIS_PROVIDER" ]; then
  PROVIDER="$PONTIS_PROVIDER"
elif [ -n "$PONTIS_UPSTREAM_URL" ]; then
  PROVIDER="local"
fi

if [ -z "$PROVIDER" ]; then
  echo "============================================="
  echo "            Select API Provider              "
  echo "============================================="
  echo "1) OpenCode (Zen/Go) - Cloud Models [Default]"
  echo "2) Local Models (Ollama, LM Studio, vLLM, etc.)"
  echo ""
  read -r -p "Select option [1-2]: " PROVIDER_SEL
  if [ "$PROVIDER_SEL" = "2" ]; then
    PROVIDER="local"
  else
    PROVIDER="opencode"
  fi
fi

# ─────────────────────────────────────────────
# 2. Setup Authentication (API Key) & Provider Configs
# ─────────────────────────────────────────────
if [ "$PROVIDER" = "local" ]; then
  # Local Provider
  if [ -n "$LOCAL_API_KEY" ]; then
    API_KEY="$LOCAL_API_KEY"
  elif [ -n "$OPENAI_API_KEY" ]; then
    API_KEY="$OPENAI_API_KEY"
  else
    # Default dummy key to satisfy proxy key validation
    API_KEY="local-model-dummy-api-key-value-32-chars-long"
  fi

  if [ -z "$PONTIS_UPSTREAM_URL" ]; then
    echo ""
    echo "============================================="
    echo "       Select Local Model Engine             "
    echo "============================================="
    echo "1) Ollama (http://localhost:11434/v1) [Default]"
    echo "2) LM Studio (http://localhost:1234/v1)"
    echo "3) Llama.cpp (http://localhost:8080/v1)"
    echo "4) Custom URL"
    echo ""
    read -r -p "Select option [1-4]: " ENGINE_OPT
    if [ "$ENGINE_OPT" = "2" ]; then
      LOCAL_URL="http://localhost:1234/v1"
    elif [ "$ENGINE_OPT" = "3" ]; then
      LOCAL_URL="http://localhost:8080/v1"
    elif [ "$ENGINE_OPT" = "4" ]; then
      read -r -p "Enter custom endpoint URL: " LOCAL_URL
      if [ -z "$LOCAL_URL" ]; then
        echo "Error: URL cannot be empty."
        exit 1
      fi
    else
      LOCAL_URL="http://localhost:11434/v1"
    fi
    export PONTIS_UPSTREAM_URL="$LOCAL_URL"
  else
    export PONTIS_UPSTREAM_URL="$PONTIS_UPSTREAM_URL"
  fi

  if [ -z "$PONTIS_UPSTREAM_FORMAT" ]; then
    export PONTIS_UPSTREAM_FORMAT="openai"
  else
    export PONTIS_UPSTREAM_FORMAT="$PONTIS_UPSTREAM_FORMAT"
  fi
else
  # OpenCode Provider
  if [ -n "$OPENCODE_API_KEY" ]; then
      API_KEY="$OPENCODE_API_KEY"
  elif [ -f "$KEY_FILE" ]; then
      API_KEY=$(cat "$KEY_FILE")
  else
      echo "============================================="
      echo "       OpenCode API Key Setup Required       "
      echo "============================================="
      echo ""
      echo "To get your key:"
      echo "  1. Go to https://opencode.ai"
      echo "  2. Sign in / create account"
      echo "  3. Navigate to Zen → API Keys"
      echo "  4. Create a new key and copy it"
      echo ""
      read -r -p "Enter your OpenCode API Key: " API_KEY
      if [ -z "$API_KEY" ]; then
          echo "Error: API Key is required."
          exit 1
      fi
      read -r -p "Save this key to $KEY_FILE for future use? (y/n): " SAVE_KEY
      if [[ "$SAVE_KEY" =~ ^[Yy]$ ]]; then
          echo "$API_KEY" > "$KEY_FILE"
          chmod 600 "$KEY_FILE"
          echo "✓ Saved API key to $KEY_FILE"
      fi
  fi
  # Trim API_KEY
  API_KEY=$(echo "$API_KEY" | xargs | tr -d '\r')
fi

# ─────────────────────────────────────────────
# 3. Select Client Mode
# ─────────────────────────────────────────────
CLIENT_CMD=""

if [ "$1" = "claude" ]; then
  CLIENT_CMD="claude"
  shift
elif [ "$1" = "codex" ]; then
  CLIENT_CMD="codex"
  shift
elif [ -n "$1" ]; then
  # Custom command specified by user
  CLIENT_CMD="$1"
  shift
else
  # Prompt selector if no arguments are passed
  echo "============================================="
  echo "         Pontis CLI Client Selector          "
  echo "============================================="
  echo "1) Claude Code (pontis claude)"
  echo "2) OpenAI Codex CLI (pontis codex)"
  echo "3) Standalone Proxy (runs background proxy only)"
  echo ""
  read -r -p "Select client to launch [1-3, default: 1]: " CLIENT_OPT
  if [ "$CLIENT_OPT" = "1" ]; then
    CLIENT_CMD="claude"
  elif [ "$CLIENT_OPT" = "2" ]; then
    CLIENT_CMD="codex"
  elif [ "$CLIENT_OPT" = "3" ]; then
    CLIENT_CMD="standalone"
  else
    echo "Defaulting to Claude Code..."
    CLIENT_CMD="claude"
  fi
fi

# ─────────────────────────────────────────────
# 4. Select Model
# ─────────────────────────────────────────────
if [ "$PROVIDER" = "local" ]; then
  # Fetch available local models concurrently
  node -e '
  const upstream = process.argv[1];
  const apiKey = process.argv[2];
  async function main() {
    try {
      const res = await fetch(`${upstream}/models`, {
        headers: apiKey && apiKey !== "local-model-dummy-api-key-value-32-chars-long" ? { "Authorization": `Bearer ${apiKey}` } : {}
      });
      if (!res.ok) throw new Error();
      const json = await res.json();
      if (!json || !Array.isArray(json.data)) throw new Error();
      const models = json.data.map(m => m.id);
      console.log(models.join(" "));
    } catch (e) {
      console.log("");
    }
  }
  main();
  ' "$PONTIS_UPSTREAM_URL" "$API_KEY" > /tmp/pontis_local_models.txt 2>/dev/null &
  NODE_PID=$!

  spin='|/-\'
  while kill -0 $NODE_PID 2>/dev/null; do
    printf "\rChecking available local models... [%c] " "$spin"
    spin=${spin#?}${spin%?}
    sleep 0.1
  done
  printf "\rChecking available local models... Done!   \n"

  LOCAL_MODELS=($(cat /tmp/pontis_local_models.txt))
  rm -f /tmp/pontis_local_models.txt

  if [ ${#LOCAL_MODELS[@]} -eq 0 ]; then
    echo "⚠ Could not fetch models from $PONTIS_UPSTREAM_URL."
    echo "Please make sure your local engine (Ollama/LM Studio) is running."
    echo ""
    read -r -p "Enter local model name (e.g. llama3, qwen2.5-coder): " MODEL
    if [ -z "$MODEL" ]; then
      echo "Error: Model name is required."
      exit 1
    fi
  else
    echo ""
    echo "============================================="
    echo "       Select Local Model                    "
    echo "============================================="
    for i in "${!LOCAL_MODELS[@]}"; do
      echo "$((i+1))) ${LOCAL_MODELS[$i]}"
    done
    CUSTOM_OPT=$(( ${#LOCAL_MODELS[@]} + 1 ))
    echo "${CUSTOM_OPT}) Custom (enter model ID manually)"
    echo ""
    read -r -p "Select option [1-${CUSTOM_OPT}]: " MODEL_OPT

    if [[ "$MODEL_OPT" =~ ^[0-9]+$ ]] && [ "$MODEL_OPT" -ge 1 ] && [ "$MODEL_OPT" -le "${#LOCAL_MODELS[@]}" ]; then
      MODEL="${LOCAL_MODELS[$((MODEL_OPT-1))]}"
    else
      read -r -p "Enter custom model ID: " MODEL
      if [ -z "$MODEL" ]; then
        MODEL="${LOCAL_MODELS[0]}"
      fi
    fi
  fi
else
  # Fetch and verify free models concurrently using Node.js
  # Running in the background with a loading spinner to prevent lag perception
  node -e '
  const apiKey = process.argv[1];

  async function checkModel(model) {
    try {
      const res = await fetch("https://opencode.ai/zen/v1/chat/completions", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${apiKey}`
        },
        body: JSON.stringify({
          model: model,
          messages: [{ role: "user", content: "ping" }],
          max_tokens: 1
        })
      });
      if (res.status === 200) {
        const data = await res.json();
        if (data && !data.error) {
          return { model, ok: true };
        }
      }
      return { model, ok: false };
    } catch (e) {
      return { model, ok: false };
    }
  }

  async function main() {
    try {
      const res = await fetch("https://opencode.ai/zen/v1/models", {
        headers: { "Authorization": `Bearer ${apiKey}` }
      });
      if (!res.ok) throw new Error();
      const json = await res.json();
      if (!json || !Array.isArray(json.data)) throw new Error();

      const candidates = json.data
        .map(m => m.id)
        .filter(id => (id.endsWith("-free") && id !== "minimax-m3-free") || id === "big-pickle");

      const results = await Promise.all(candidates.map(checkModel));
      const working = results.filter(r => r.ok).map(r => r.model);
      console.log(working.join(" "));
    } catch (e) {
      console.log("");
    }
  }

  main();
  ' "$API_KEY" > /tmp/pontis_models.txt 2>/dev/null &
  NODE_PID=$!

  spin='|/-\'
  while kill -0 $NODE_PID 2>/dev/null; do
    printf "\rChecking available free models on OpenCode... [%c] " "$spin"
    spin=${spin#?}${spin%?}
    sleep 0.1
  done
  printf "\rChecking available free models on OpenCode... Done!   \n"

  FREE_MODELS=($(cat /tmp/pontis_models.txt))
  rm -f /tmp/pontis_models.txt

  # Fallback list if fetching or verifying fails
  if [ ${#FREE_MODELS[@]} -eq 0 ]; then
    FREE_MODELS=("mimo-v2.5-free" "deepseek-v4-flash-free" "big-pickle" "nemotron-3-ultra-free" "north-mini-code-free")
  fi

  echo ""
  echo "============================================="
  echo "       Select OpenCode Free Model            "
  echo "============================================="
  for i in "${!FREE_MODELS[@]}"; do
    echo "$((i+1))) ${FREE_MODELS[$i]}"
  done
  CUSTOM_OPT=$(( ${#FREE_MODELS[@]} + 1 ))
  echo "${CUSTOM_OPT}) Custom (enter model ID manually)"

  read -r -p "Select option [1-${CUSTOM_OPT}]: " MODEL_OPT

  # Check selection
  if [[ "$MODEL_OPT" =~ ^[0-9]+$ ]] && [ "$MODEL_OPT" -ge 1 ] && [ "$MODEL_OPT" -le "${#FREE_MODELS[@]}" ]; then
    MODEL="${FREE_MODELS[$((MODEL_OPT-1))]}"
  elif [ "$MODEL_OPT" -eq "${CUSTOM_OPT}" ]; then
    read -r -p "Enter custom model ID: " MODEL
    if [ -z "$MODEL" ]; then
      echo "Error: Model ID cannot be empty."
      exit 1
    fi
  else
    # Default to the first model in the list
    MODEL="${FREE_MODELS[0]}"
    echo "Defaulting to $MODEL"
  fi
fi

echo "Selected Model: $MODEL"

# ─────────────────────────────────────────────
# 5. Start/Reuse Proxy
# ─────────────────────────────────────────────
# Always restart the proxy on port $PORT to ensure latest configuration/upstream environment variables are applied
if lsof -i :$PORT >/dev/null 2>&1; then
    echo "⚡ Restarting local Pontis proxy on port $PORT..."
    lsof -t -i :$PORT | xargs kill -9 2>/dev/null || true
    sleep 0.5
fi

LAUNCH_PROXY=true
PROXY_PID=""

cleanup() {
    if [ "$LAUNCH_PROXY" = true ] && [ -n "$PROXY_PID" ]; then
        echo ""
        echo "Stopping local Pontis proxy..."
        kill "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
    fi
}
trap cleanup EXIT INT TERM

# Ensure dependencies are installed
if [ ! -d "$PROXY_DIR/node_modules" ]; then
    echo "Installing proxy dependencies..."
    (cd "$PROXY_DIR" && npm install --silent 2>/dev/null)
fi

# Start local server
PROXY_LOG="$PROXY_DIR/proxy.log"
(cd "$PROXY_DIR" && npx tsx src/local-server.ts > "$PROXY_LOG" 2>&1) &
PROXY_PID=$!

# Wait for proxy to become ready with a spinner
spin='|/-\'
i=0
while ! curl -s -f "$PROXY_URL/" >/dev/null 2>&1; do
  printf "\rWaiting for proxy to start... [%c] " "$spin"
  spin=${spin#?}${spin%?}
  sleep 0.1
  i=$((i+1))
  if [ $i -ge 120 ]; then
    echo ""
    echo "Error: Proxy failed to start on port $PORT within 12 seconds."
    echo "Check logs: $PROXY_LOG"
    exit 1
  fi
done
printf "\rWaiting for proxy to start... ✓ Ready!      \n"

# ─────────────────────────────────────────────
# 6. Quick connectivity test
# ─────────────────────────────────────────────
# Run test in background with a loader spinner
(curl -s -w "\n%{http_code}" -X POST "$PROXY_URL/zen/v1/messages" \
    -H "Content-Type: application/json" \
    -H "x-api-key: $API_KEY" \
    -H "anthropic-version: 2023-06-01" \
    -d '{
        "model": "'"$MODEL"'",
        "max_tokens": 5,
        "messages": [{"role": "user", "content": "hi"}]
    }' 2>/dev/null || echo "CURL_FAILED") > /tmp/pontis_test.txt &
TEST_PID=$!

spin='|/-\'
while kill -0 $TEST_PID 2>/dev/null; do
  printf "\rTesting API connectivity... [%c] " "$spin"
  spin=${spin#?}${spin%?}
  sleep 0.1
done

TEST_RESPONSE=$(cat /tmp/pontis_test.txt)
rm -f /tmp/pontis_test.txt

if echo "$TEST_RESPONSE" | grep -q "CURL_FAILED"; then
    printf "\rTesting API connectivity... ⚠ Could not reach proxy (continuing anyway)\n"
else
    HTTP_CODE=$(echo "$TEST_RESPONSE" | tail -1)
    BODY=$(echo "$TEST_RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" = "200" ] || echo "$BODY" | grep -q '"type":"message"'; then
        printf "\rTesting API connectivity... ✓ Connected!      \n"
    elif [ "$HTTP_CODE" = "401" ]; then
        printf "\rTesting API connectivity... ⚠ API returned 401 Unauthorized.\n"
        echo "Your API key may be invalid or expired."
        echo "Response: $(echo "$BODY" | head -c 200)"
        echo ""
        read -r -p "Continue anyway? (y/n): " CONTINUE
        if [[ ! "$CONTINUE" =~ ^[Yy]$ ]]; then
            exit 1
        fi
    else
        printf "\rTesting API connectivity... ⚠ Got HTTP %s (continuing)\n" "$HTTP_CODE"
    fi
fi

# ─────────────────────────────────────────────
# 7. Launch Client (Claude Code / Codex CLI / Standalone)
# ─────────────────────────────────────────────
echo ""
echo "============================================="
echo "        Launching Pontis CLI Harness         "
echo "============================================="
echo "Proxy:    $PROXY_URL"
echo "Model:    $MODEL"
echo ""

if [ "$CLIENT_CMD" = "standalone" ]; then
  echo "Running in standalone proxy mode."
  echo "Connect your clients to $PROXY_URL"
  echo "Press Ctrl+C to stop the proxy server."
  # Keep script running to prevent cleanup trap from executing immediately
  while true; do sleep 10; done
fi

# Check CLI execution path
FINAL_CMD=""

if [ "$CLIENT_CMD" = "codex" ]; then
  echo "Launching Codex CLI..."
  # Map standard OpenAI base URLs to our proxy for Codex CLI
  export OPENAI_BASE_URL="$PROXY_URL/v1"
  export OPENAI_API_KEY="$API_KEY"
  
  if command -v codex >/dev/null 2>&1; then
    FINAL_CMD="codex"
  elif command -v openai-codex >/dev/null 2>&1; then
    FINAL_CMD="openai-codex"
  else
    echo "⚠ Codex CLI not found in PATH."
    echo "Make sure you have your Codex CLI installed."
    exit 1
  fi
elif [ "$CLIENT_CMD" = "claude" ]; then
  # Default to Claude Code
  FINAL_CMD="claude"
  
  # Auto-approve the API key in ~/.claude.json to prevent OAuth fallback / prompt
  node -e '
  const fs = require("fs");
  const path = require("path");
  const configFile = path.join(process.env.HOME, ".claude.json");
  const keySuffix = process.argv[1].slice(-20);
  if (fs.existsSync(configFile)) {
    try {
      const config = JSON.parse(fs.readFileSync(configFile, "utf8"));
      if (!config.customApiKeyResponses) config.customApiKeyResponses = {};
      if (!config.customApiKeyResponses.approved) config.customApiKeyResponses.approved = [];
      if (!config.customApiKeyResponses.approved.includes(keySuffix)) {
        config.customApiKeyResponses.approved.push(keySuffix);
      }
      if (config.customApiKeyResponses.rejected) {
        config.customApiKeyResponses.rejected = config.customApiKeyResponses.rejected.filter(k => k !== keySuffix);
      }
      fs.writeFileSync(configFile, JSON.stringify(config, null, 2), "utf8");
      console.log("✓ Auto-approved API key suffix in ~/.claude.json");
    } catch (e) {
      console.error("Failed to auto-approve API key in config:", e);
    }
  }
  ' "$API_KEY"

  export ANTHROPIC_BASE_URL="$PROXY_URL/zen"
  export ANTHROPIC_API_KEY="$API_KEY"
  export ANTHROPIC_MODEL="$MODEL"
  export ANTHROPIC_SMALL_FAST_MODEL="$MODEL"
else
  # Custom command specified by user
  FINAL_CMD="$CLIENT_CMD"
  # Export both configurations to cover any CLI
  export ANTHROPIC_BASE_URL="$PROXY_URL/zen"
  export ANTHROPIC_API_KEY="$API_KEY"
  export ANTHROPIC_MODEL="$MODEL"
  export ANTHROPIC_SMALL_FAST_MODEL="$MODEL"
  export OPENAI_BASE_URL="$PROXY_URL/v1"
  export OPENAI_API_KEY="$API_KEY"
fi

echo "Running command: $FINAL_CMD $@"
exec "$FINAL_CMD" "$@"
